<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="brand">#3B82F6</color>
    <color name="brand_light">#76B7FF</color>
    <color name="brand_soft">#1D4ED8</color>
    <color name="card">#142238</color>
    <color name="card_pressed">#1B2D49</color>
    <color name="danger">#FB7185</color>
    <color name="divider">#26364F</color>
    <color name="success">#34D399</color>
    <color name="surface">#08101F</color>
    <color name="surface_alt">#0D1729</color>
    <color name="text_primary">#F8FAFC</color>
    <color name="text_secondary">#A9B7CA</color>
    <color name="warning">#FBBF24</color>
    <string name="app_name">A56 Toolkit Pro</string>
    <style name="DexActionCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/action_card_bg</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">16dp</item>
    </style>
    <style name="DexArrow">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:tint">@color/text_secondary</item>
    </style>
    <style name="DexArrowIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:alpha">0.55</item>
        <item name="android:contentDescription">Abrir</item>
    </style>
    <style name="DexCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/card_pressed</item>
    </style>
    <style name="DexCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">18dp</item>
    </style>
    <style name="DexCardIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:contentDescription">Ícone</item>
    </style>
    <style name="DexCardState">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/brand_light</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="DexCardStatus">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textColor">@color/brand_light</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="DexCardSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>
    <style name="DexCardTextBlock">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">15dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>
    <style name="DexCardTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="DexIconTile">
        <item name="android:layout_width">54dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/icon_tile</item>
        <item name="android:foregroundGravity">center</item>
    </style>
    <style name="DexPrimaryCard" parent="DexCard">
        <item name="strokeColor">@color/brand</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="DexSmallCard" parent="DexCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:minHeight">110dp</item>
    </style>
    <style name="DexSmallCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">16dp</item>
    </style>
    <style name="DexSmallCardSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="DexSmallCardTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">28dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    <style name="Theme.A56Toolkit" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorSecondary">@color/brand</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#07101E</item>
        <item name="android:navigationBarColor">#07101E</item>
        <item name="android:windowBackground">@drawable/home_gradient</item>
    </style>
</resources>