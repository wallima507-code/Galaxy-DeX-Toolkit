<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/surface">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
    <TextView android:text="Dispositivo e bateria" android:textSize="28sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvInfo" android:background="@drawable/card_bg" android:textSize="15sp" android:lineSpacingExtra="7dp" android:textColor="@color/text_primary" android:layout_marginTop="18dp" android:padding="18dp" android:textIsSelectable="true" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnRefresh" android:text="Atualizar bateria" android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnCopy" android:text="Copiar relatório" style="@style/Widget.Material3.Button.TonalButton" android:layout_marginTop="8dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout></ScrollView>
