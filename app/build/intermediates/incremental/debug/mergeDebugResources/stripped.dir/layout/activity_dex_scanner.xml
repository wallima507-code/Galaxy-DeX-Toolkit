<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DeX Scanner 3.0"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Análise automática dos componentes DeX, monitor, periféricos e ADB."
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical">

            <TextView
                android:text="RESULTADO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScoreDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/brand_light"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:text="COMPONENTES DEX" />
        <TextView
            android:id="@+id/tvComponents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/action_card_bg"
            android:fontFamily="monospace"
            android:lineSpacingExtra="5dp"
            android:padding="18dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView style="@style/SectionLabel" android:text="MONITOR EXTERNO" />
        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/action_card_bg"
            android:padding="18dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView style="@style/SectionLabel" android:text="RATO E TECLADO" />
        <TextView
            android:id="@+id/tvInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/action_card_bg"
            android:lineSpacingExtra="4dp"
            android:padding="18dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView style="@style/SectionLabel" android:text="DEPURAÇÃO" />
        <TextView
            android:id="@+id/tvAdb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/action_card_bg"
            android:padding="18dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Executar nova análise"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWirelessDebug"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Abrir depuração sem fios"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShare"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Partilhar relatório"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
